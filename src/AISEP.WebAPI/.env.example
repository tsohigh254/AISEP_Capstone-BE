# ============================================
# AISEP - Environment Variables Template
# Copy this file and rename to .env
# Fill in your actual secrets below
# ============================================

# --- Database ---
ConnectionStrings__DefaultConnection=Server=localhost;Database=AISEP;Port=5432;User Id=postgres;Password=

# --- JWT ---
Jwt__SecretKey=

# --- Email (Resend API) ---
Email__SmtpUser=
Email__SmtpPassword=
Email__FromEmail=
Email__ResendApiKey=

# --- Cloudinary ---
CloudinaryOptions__CloudName=
CloudinaryOptions__ApiKey=
CloudinaryOptions__ApiSecret=

# --- Blockchain (Ethereum Sepolia) ---
# Required: RPC URL, contract address, and wallet private key
Blockchain__RpcUrl=
Blockchain__ContractAddress=
Blockchain__PrivateKey=
