# ============================================
# AISEP - Environment Variables Template
# Copy this file and rename to .env
# Fill in your actual secrets below
# ============================================

# --- Database ---
ConnectionStrings__DefaultConnection=Server=localhost;Database=AISEP;Port=5432;User Id=postgres;Password=

# --- JWT ---
Jwt__SecretKey=
# Optional (có default): Jwt__Issuer=AISEP | Jwt__Audience=AISEP-Users
# Optional: Jwt__AccessTokenExpirationMinutes=60 | Jwt__RefreshTokenExpirationDays=7

# --- Email (SMTP) ---
Email__SmtpUser=
Email__SmtpPassword=
Email__FromEmail=
# URL base dùng trong link email gửi đi (đổi khi deploy lên production)
Email__BaseUrl=http://localhost:3000
# Optional: Email__SmtpHost=smtp.gmail.com | Email__SmtpPort=587 | Email__FromName=AISEP

# --- CORS ---
# Danh sách origins cho phép, phân cách bằng dấu phẩy
Cors__AllowedOrigins=http://localhost:3000

# --- Auth Cookies ---
# Đổi thành true khi deploy HTTPS
AuthCookies__Secure=false
AuthCookies__SameSite=Lax
# AuthCookies__Domain=yourdomain.com

# --- Cloudinary ---
CloudinaryOptions__CloudName=
CloudinaryOptions__ApiKey=
CloudinaryOptions__ApiSecret=

# --- Blockchain (Ethereum Sepolia) ---
# Set Provider to "Ethereum" to use real blockchain, or "Stub" for mock
Blockchain__Provider=Stub
Blockchain__RpcUrl=
Blockchain__ContractAddress=
Blockchain__PrivateKey=
